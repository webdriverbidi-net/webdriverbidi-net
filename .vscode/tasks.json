{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "dotnet",
            "task": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "dotnet: build"
        },
        {
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "--project",
                "${workspaceFolder}/test/WebDriverBiDi.Tests"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "label": "dotnet: test"
        },
        {
            "type": "shell",
            "command": "dotnet build --configuration Debug ${workspaceFolder}/test/WebDriverBiDi.Tests/WebDriverBiDi.Tests.csproj && ${workspaceFolder}/test/WebDriverBiDi.Tests/bin/Debug/net10.0/WebDriverBiDi.Tests --coverlet --coverlet-output-format lcov --coverlet-exclude-by-file '**/_/src/**' --coverlet-exclude '[WebDriverBiDi.NamedPipeTestApplication]*' --results-directory '${workspaceFolder}/test/coverage' --coverlet-file-prefix lcov",
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "label": "dotnet: test with coverage",
            "options": {
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-c"]
                }
            }
        }
    ]
}