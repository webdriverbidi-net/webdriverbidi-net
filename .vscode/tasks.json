{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "dotnet",
            "task": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "dotnet: build"
        },
        {
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/test/WebDriverBiDi.Tests"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "label": "dotnet: test"
        },
        {
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "--project",
                "${workspaceFolder}/test/WebDriverBiDi.Tests",
                "--coverlet",
                "--coverlet-output-format",
                "lcov",
                "--results-directory",
                "${workspaceFolder}/test/coverage/lcov"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "label": "dotnet: test with coverage"
        }
    ]
}